# 配置 webhook 網址 (必填)
WATCHDOG_WEBHOOK_URL="你的_DISCORD_WEBHOOK_URL"

# OpenClaw 設定檔路徑 (選填，預設為 ~/.openclaw/openclaw.json)
# OPENCLAW_CONFIG_PATH="/home/youruser/.openclaw/openclaw.json"

# 每次輪詢間隔 (選填，預設為 15 秒)
# WATCHDOG_CHECK_INTERVAL=15

# 人工修改寬限期 (選填，預設為 120 秒)
# 如果偵測到設定檔語法錯誤，但該文件在幾分鐘內持續被修改，將進入寬限期避免覆蓋進度。
# WATCHDOG_GRACE_SEC=120
