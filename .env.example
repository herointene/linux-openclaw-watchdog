# 配置 webhook 網址 (必填)
WATCHDOG_WEBHOOK_URL="https://discord.com/api/webhooks/YOUR_WEBHOOK_URL_HERE"

# OpenClaw 設定檔路徑 (選填，預設為 ~/.openclaw/openclaw.json)
# OPENCLAW_CONFIG_PATH="~/.openclaw/openclaw.json"

# 每次輪詢間隔 (選填，預設為 10 秒)
# WATCHDOG_CHECK_INTERVAL=10

# 人工修改寬限期 (選填，預設為 120 秒)
# 如果偵測到設定檔語法錯誤，但該文件在幾分鐘內持續被修改，將進入寬限期避免覆蓋進度。
# WATCHDOG_GRACE_SEC=120
